# OBLIVRA server environment file.
# Copy to /etc/oblivra/oblivra.env (mode 0600, owned by oblivra:oblivra)
# and replace the REPLACE-ME values with real secrets.

# Where the audit log, WAL, BadgerDB hot store, parquet warm tier, and
# vault file all live. Must be a real filesystem (not tmpfs / not SMB)
# with reliable fsync.
OBLIVRA_DATA_DIR=/var/lib/oblivra

# REST + UI listener. Bind to 127.0.0.1 if you front with a reverse
# proxy (Caddy/nginx); bind to 0.0.0.0:8080 if the VPN is the perimeter
# and you want clients to talk directly to the server.
OBLIVRA_ADDR=0.0.0.0:8080

# Auth — REQUIRED in production. Format: "name:role[,name:role]".
# Roles: admin (write), analyst (read+search+cases), readonly (read).
# Generate names with: openssl rand -hex 16
OBLIVRA_API_KEYS=REPLACE-ME-32HEXCHARS:admin

# Audit-chain HMAC root key — REQUIRED. Treat like a TLS private key.
# Generate with: openssl rand -hex 32
OBLIVRA_AUDIT_KEY=REPLACE-ME-64HEXCHARS

# Optional: ingestion ports.
OBLIVRA_SYSLOG_ADDR=:1514
OBLIVRA_NETFLOW_ADDR=:2055

# Optional: enable hourly daily-anchor compaction after 365d.
# OBLIVRA_AUDIT_COMPACT_AFTER=8760h

# Optional: agent allow-list. Each agent's pubkey (base64) goes here
# so the server rejects events signed by unknown keys.
# OBLIVRA_AGENT_PUBKEYS=base64key1,base64key2

# Optional: front with Caddy or nginx and bind to localhost above.
# Leave OBLIVRA_TLS_CERT / OBLIVRA_TLS_KEY unset when you do.
# OBLIVRA_TLS_CERT=/etc/oblivra/tls/cert.pem
# OBLIVRA_TLS_KEY=/etc/oblivra/tls/key.pem
