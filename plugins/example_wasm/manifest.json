{
    "id": "oblivra.example.wasm",
    "name": "Example WASM Plugin",
    "version": "1.0.0",
    "description": "A proof-of-concept WebAssembly plugin written in Go and compiled to wasip1.",
    "author": "Sovereign Engineering",
    "license": "MIT",
    "type": "terminal",
    "permissions": [
        "ssh.read",
        "events"
    ],
    "main": "main.wasm",
    "max_memory_mb": 64,
    "max_cpu_pct": 25,
    "timeout_sec": 30,
    "hooks": {
        "on_connect": true
    },
    "min_app_version": "0.1.0"
}