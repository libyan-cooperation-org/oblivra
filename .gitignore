# Binaries — ignore *.exe and the unsuffixed counterparts produced by `go build` at the repo root
*.exe
/oblivra
/oblivra-server
/oblivra-agent
/oblivra-cli
/oblivra-verify
/oblivra-migrate
/oblivra-soak
/oblivra-smoke
/build/bin/
/build/linux/dist/
/build/linux/oblivra-server-*-linux-amd64/
/build/linux/oblivra-server-*-linux-amd64.tar.gz
/build/windows/installer/OBLIVRA-Setup-*.exe
/dist/

# Frontend / Node
node_modules/
**/node_modules/
frontend/.vite/
frontend/dist/
.npm/
.pnpm-store/
.yarn/
.cache/
*.tsbuildinfo

# Generated assets / bindings
# webassets/dist contains a checked-in placeholder so the Go embed compiles on
# fresh checkouts; real builds overwrite it.
/webassets/dist/*
!/webassets/dist/index.html
/frontend/bindings/

# Go
*.test
*.out
coverage.*

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Runtime data
/data/
/tmp/
*.log
*.vault
*.badger/
*.bleve/

# Task / cache
.task/

# Local secrets / credentials
.env
.env.local
.env.*.local
*.pem
*.key
oblivra.vault
agent.ed25519*

# Profiling output
*.pprof
*.prof

# Backups
*.bak
*.backup
*.pre-migrate
