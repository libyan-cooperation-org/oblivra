{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Oblivra Sovereign Terminal — platform health, detection activity, and SSH operations",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Platform Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Goroutines",
      "type": "stat",
      "targets": [{ "expr": "goroutine_count", "legendFormat": "goroutines", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Heap Allocated",
      "type": "stat",
      "targets": [{ "expr": "memory_usage_bytes", "legendFormat": "heap", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Active SSH Sessions",
      "type": "stat",
      "targets": [{ "expr": "sessions_active", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Vault Unlock Failures",
      "type": "stat",
      "targets": [{ "expr": "increase(vault_unlock_failed[1h])", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Detection Rules Loaded",
      "type": "stat",
      "targets": [{ "expr": "detection_rules_loaded", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Sigma Rules Loaded",
      "type": "stat",
      "targets": [{ "expr": "detection_rules_sigma", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Detection Activity",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "none", "spanNulls": false }, "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byLabelValue", "options": { "label": "severity", "value": "critical" } }, "properties": [{ "id": "color", "value": { "fixedColor": "#f85149", "mode": "fixed" } }] },
          { "matcher": { "id": "byLabelValue", "options": { "label": "severity", "value": "high" } }, "properties": [{ "id": "color", "value": { "fixedColor": "#d29922", "mode": "fixed" } }] },
          { "matcher": { "id": "byLabelValue", "options": { "label": "severity", "value": "medium" } }, "properties": [{ "id": "color", "value": { "fixedColor": "#2f81f7", "mode": "fixed" } }] },
          { "matcher": { "id": "byLabelValue", "options": { "label": "severity", "value": "low" } }, "properties": [{ "id": "color", "value": { "fixedColor": "#3fb950", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] } },
      "title": "Detections by Severity (rate/min)",
      "type": "timeseries",
      "targets": [{ "expr": "rate(detections_total[1m])", "legendFormat": "{{severity}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 11,
      "options": { "pieType": "donut", "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "title": "Detection Mix (total)",
      "type": "piechart",
      "targets": [{ "expr": "detections_total", "legendFormat": "{{severity}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "SSH Operations",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80 }, "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "SSH Connections (success vs failed)",
      "type": "timeseries",
      "targets": [
        { "expr": "increase(ssh_connections_success[1m])", "legendFormat": "success", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "increase(ssh_connections_failed[1m])", "legendFormat": "failed", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "#58a6ff" }, "unit": "ms" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "SSH Connection Latency (p95)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(ssh_connection_latency_ms_bucket[5m]))", "legendFormat": "p95 latency", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 103,
      "title": "Distributed Traces (Tempo)",
      "type": "row"
    },

    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "options": {
        "query": { "queryType": "nativeSearch", "serviceName": "oblivrashell" },
        "search": { "hide": false }
      },
      "title": "Recent Traces — oblivrashell",
      "type": "traces"
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["oblivra", "siem", "security"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Oblivra Platform",
  "uid": "oblivra-platform",
  "version": 1
}
